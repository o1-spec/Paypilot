# PayPilot Django Environment Variables Configuration Template
# Copy this file to '.env' inside the backend/ folder and customize values.

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-paypilot-hackathon-development-key-1002
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database Configuration ────────────────────────────────────────────────────
# Defaults to SQLite if USE_SQLITE=True or if DB_NAME is not set.
# Switch to PostgreSQL for production.
USE_SQLITE=True
# DATABASE_URL=postgres://user:password@localhost:5432/paypilot
# DB_NAME=paypilot
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432

# ── CORS Configuration ────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True

# ── Virtual Account Provider ─────────────────────────────────────────────────
# NombaProvider: attempts real Nomba API calls (falls back to mock if credentials absent)
# MockNombaProvider: always uses mock data (safe for testing without credentials)
VIRTUAL_ACCOUNT_PROVIDER=virtual_accounts.providers.NombaProvider

# ── Nomba API Credentials (Sandbox) ──────────────────────────────────────────
# Obtain from: https://dashboard.nomba.com → Settings → API Keys
# Leave blank to use mock mode (demo will still work without credentials).
NOMBA_ENV=sandbox
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=

# ── Nomba Webhook Signing Key ─────────────────────────────────────────────────
# Configure this on your Nomba Dashboard → Webhooks → Signing Secret.
# If left blank, signature verification is skipped (safe for sandbox testing).
NOMBA_WEBHOOK_SIGNING_KEY=
