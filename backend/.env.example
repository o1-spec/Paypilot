# PayPilot Django Environment Variables Configuration Template
# Copy this file to '.env' inside the backend/ folder and customize values.

# Security
SECRET_KEY=django-insecure-paypilot-hackathon-development-key-1002
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Defaults to sqlite if database_url is not set)
# DATABASE_URL=postgres://user:password@localhost:5432/paypilot

# CORS Configurations
CORS_ALLOW_ALL_ORIGINS=True

# Provisioning Provider (Stage 1 uses MockNombaProvider)
VIRTUAL_ACCOUNT_PROVIDER=virtual_accounts.providers.MockNombaProvider
